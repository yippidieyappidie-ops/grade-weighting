{
  "rewrites": [
    {
      "source": "/ads.txt",
      "destination": "/ads.txt"
    },
    {
      "source": "/__/auth/:path*",
      "destination": "/app"
    },
    {
      "source": "/app",
      "destination": "/app/index-bundled.html"
    },
    {
      "source": "/app/",
      "destination": "/app/index-bundled.html"
    }
  ]
}
